# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Subscription catalog PNGs under public/subscription-icons/ are committed to the repo.

# next-pwa build output (regenerated each build)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/worker-*.js
public/fallback-*.js

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit only `.env.example` (native template); never commit secrets
.env*
!.env.example
# Optional full pull for `vercel dev` (do not use for Capacitor builds)
.env.vercel

# vercel
.vercel

# Admin-managed AI runtime (local / persistent server only)
/data/ai-runtime-config.json

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# Capacitor native projects (regenerated by `npx cap add android` / `npx cap add ios`)
/android/
/ios/
*.keystore
*.jks

# Capacitor build stash (used by scripts/capacitor-build.mjs)
/.cap-stash/

dist/
.claude/*.log
.claude/linear-bot.log
