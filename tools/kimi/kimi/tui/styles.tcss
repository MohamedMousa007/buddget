/* Minimalistic dark TUI matching Claude Code's visual feel. */

Screen {
    background: #0c0c0e;
    color: #e6e6e6;
}

#top-bar {
    height: 3;
    background: #131317;
    border-bottom: solid #2a2a30;
    padding: 0 1;
}

#controls {
    height: 3;
    align: left middle;
}

#controls Select {
    width: 22;
    margin-right: 1;
    background: #18181d;
    color: #e6e6e6;
}

#controls Button {
    width: 10;
    margin-left: 1;
    background: #18181d;
    color: #e6e6e6;
    border: solid #2a2a30;
}

#controls Button:hover {
    background: #22222a;
}

#output {
    background: #0c0c0e;
    color: #d6d6d6;
    padding: 1 2;
    border: none;
}

#status-bar {
    height: 1;
    background: #131317;
    color: #9aa0a6;
    padding: 0 2;
    border-top: solid #2a2a30;
    border-bottom: solid #2a2a30;
}

#status-text {
    width: 100%;
    color: #9aa0a6;
}

#input-bar {
    height: 3;
    background: #131317;
    padding: 0 1;
}

#user-input {
    background: #18181d;
    color: #e6e6e6;
    border: solid #2a2a30;
    margin-right: 1;
}

#user-input:focus {
    border: solid #4f7ad6;
}

#attach-btn {
    width: 4;
    background: #18181d;
    color: #e6e6e6;
    border: solid #2a2a30;
}

#send-btn {
    width: 10;
    background: #4f7ad6;
    color: #ffffff;
    border: solid #4f7ad6;
}

#send-btn:hover {
    background: #5a85e0;
}

PlanModal {
    align: center middle;
}

#plan-panel {
    width: 80%;
    max-width: 100;
    height: auto;
    max-height: 90%;
    border: solid #4f7ad6;
    background: #131317;
    padding: 1 2;
}

#plan-panel #plan-buttons {
    height: 3;
    margin-top: 1;
    align: right middle;
}

#plan-panel Button {
    margin-left: 1;
    min-width: 10;
}
