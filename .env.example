# Copy to `.env.local` for local development (never commit `.env.local`).
#
# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in emails / redirects). Production: https://buddget.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth providers — set to true only after enabling the provider in Supabase Auth
# and completing Google Cloud / Apple Developer console setup (see supabase/README.md).
NEXT_PUBLIC_OAUTH_GOOGLE=false
NEXT_PUBLIC_OAUTH_APPLE=false

# Gemini AI — server-side only
GEMINI_API_KEY=

# Admin panel PIN
ADMIN_PIN=

# Web Push (VAPID) — SMS auto-tracking background notifications
# Generate once with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose to the browser.
# VAPID_PRIVATE_KEY must remain server-side only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact info sent to push services (mailto: or https: URL)
VAPID_SUBJECT=mailto:hello@buddget.app

# Native (iOS + Android) push via Firebase Cloud Messaging
# `FIREBASE_SERVICE_ACCOUNT_JSON` is the full service-account JSON as a single
# string (escaped newlines OK). Server-side only.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Public Firebase project id (used in iOS GoogleService-Info.plist + Android google-services.json)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Firebase web push VAPID key (for FCM JS SDK in the WebView, optional)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Capacitor native shell calls the API at this origin (e.g. https://buddget.app).
# Leave blank for the web build — relative `/api/...` continues to work.
NEXT_PUBLIC_API_BASE_URL=

# Groq Whisper API key for voice expense transcription
GROQ_API_KEY=

# Optional: bearer token for the Android Notification Listener fallback
# (mirrors the iOS Shortcuts token at sms_ingest_tokens). Leave unset to
# require per-user provisioning in Settings.
NOTIFICATION_LISTENER_SHARED_SECRET=
