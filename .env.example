# Buddget — local `.env.local` for native (iOS / Android) builds ONLY
#
# Setup (once):
#   cp .env.example .env.local
#   # Fill Supabase URL + publishable key from Supabase → Settings → API
#
# Server secrets (GEMINI, SUPABASE_SECRET_KEY, Firebase admin, admin PIN, etc.)
# live on Vercel only. The native app calls https://buddget.app for /api/*.
#
# Do NOT run `vercel env pull .env.local` — that mixes server keys you do not need locally.
# Full local web + API dev: use `vercel dev` (loads env from the Vercel project).
#
# Validate: npm run cap:env:check
# Build:    npm run cap:build

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

NEXT_PUBLIC_API_BASE_URL=https://buddget.app
NEXT_PUBLIC_APP_URL=https://buddget.app

NEXT_PUBLIC_OAUTH_GOOGLE=true
NEXT_PUBLIC_OAUTH_APPLE=true

# Native (Capacitor) Google sign-in via signInWithIdToken. Build-time inlined.
# Without the iOS client ID, native Google falls back to the web-redirect flow.
# iOS OAuth client ID + Web client ID from Google Cloud → APIs & Services → Credentials.
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Voice transcription (Groq Whisper). Server-side only — set on Vercel for prod.
# Generate a free key at https://console.groq.com/keys (format gsk_...).
# For local `npm run dev` voice testing, add the real key to .env.local.
GROQ_API_KEY=
