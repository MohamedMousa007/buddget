# Copy to `.env.local` for local development (never commit `.env.local`).
#
# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in emails / redirects). Production: https://buddget.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini AI — server-side only
GEMINI_API_KEY=

# Admin panel PIN
ADMIN_PIN=

# Web Push (VAPID) — SMS auto-tracking background notifications
# Generate once with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose to the browser.
# VAPID_PRIVATE_KEY must remain server-side only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact info sent to push services (mailto: or https: URL)
VAPID_SUBJECT=mailto:hello@buddget.app
